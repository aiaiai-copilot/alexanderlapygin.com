---
import BaseLayout from "~/layouts/BaseLayout.astro";
import BlogCatalog from "~/components/BlogCatalog.astro";
import { t } from "~/i18n";

const locale = "ru" as const;
const dict = t(locale);
---

<BaseLayout locale={locale} title={dict.blog.title}>
  <BlogCatalog locale={locale} />
</BaseLayout>
