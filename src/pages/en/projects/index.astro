---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectsCatalog from "~/components/ProjectsCatalog.astro";
import { t } from "~/i18n";

const locale = "en" as const;
const dict = t(locale);
---

<BaseLayout locale={locale} title={dict.projects.title}>
  <ProjectsCatalog locale={locale} />
</BaseLayout>
