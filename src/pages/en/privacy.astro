---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PrivacyPage from "~/components/PrivacyPage.astro";
import { t } from "~/i18n";

const locale = "en" as const;
const dict = t(locale);
---

<BaseLayout locale={locale} title={dict.privacy.title}>
  <PrivacyPage locale={locale} />
</BaseLayout>
