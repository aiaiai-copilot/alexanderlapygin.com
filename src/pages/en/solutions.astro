---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SolutionsPage from "~/components/SolutionsPage.astro";
import { t } from "~/i18n";

const locale = "en" as const;
const dict = t(locale);
---

<BaseLayout locale={locale} title={dict.solutions.title}>
  <SolutionsPage locale={locale} />
</BaseLayout>
