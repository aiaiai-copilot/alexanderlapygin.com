---
import { t, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<section class="mx-auto max-w-3xl px-4 md:px-6 pt-8 md:pt-12 pb-8 md:pb-10 text-center">
  <img
    src="/photo.png"
    alt={dict.meta.siteAuthor}
    width="160"
    height="160"
    class="mx-auto w-32 h-32 md:w-40 md:h-40 rounded-2xl object-cover"
    loading="eager"
    decoding="async"
  />
  <h1 class="mt-8 text-3xl md:text-5xl font-semibold tracking-tight" style="color: var(--color-text);">
    {dict.home.heroSubtitle}
  </h1>
  <p
    class="mt-6 text-base md:text-lg leading-relaxed whitespace-pre-line"
    style="color: var(--color-text-muted);"
  >
    {dict.home.heroTagline}
  </p>
</section>

<section class="mx-auto max-w-3xl px-4 md:px-6 pb-8 md:pb-10">
  <div
    class="rounded-xl p-6 md:p-10 border text-center"
    style="background-color: var(--color-bg-elev); border-color: var(--color-border);"
  >
    <h2 class="text-xl md:text-2xl font-semibold tracking-tight mb-4" style="color: var(--color-text);">
      {dict.home.sdd.title}
    </h2>
    <p class="text-base md:text-lg leading-relaxed" style="color: var(--color-text-muted);">
      {dict.home.sdd.description}
    </p>
  </div>
</section>

<section class="mx-auto max-w-6xl px-4 md:px-6 pb-8 md:pb-12">
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
    {dict.home.advantages.map((a) => (
      <div
        class="rounded-lg p-5 border h-full text-center"
        style="background-color: var(--color-bg); border-color: var(--color-border);"
      >
        <h3 class="font-semibold text-base mb-2" style="color: var(--color-text);">
          {a.title}
        </h3>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          {a.body}
        </p>
      </div>
    ))}
  </div>
</section>
