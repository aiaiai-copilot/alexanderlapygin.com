---
import { localizedPath, t, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<section class="mx-auto max-w-3xl px-4 md:px-6 pt-20 md:pt-32 pb-16 text-center">
  <div class="text-6xl md:text-8xl font-bold mb-6" style="color: var(--color-text-muted);">404</div>
  <h1 class="text-2xl md:text-4xl font-semibold tracking-tight mb-4" style="color: var(--color-text);">
    {dict.notFound.title}
  </h1>
  <p class="text-base md:text-lg max-w-xl mx-auto mb-10" style="color: var(--color-text-muted);">
    {dict.notFound.body}
  </p>
  <div class="flex flex-wrap items-center justify-center gap-3">
    {[
      { href: localizedPath(locale, "/"), label: dict.notFound.home },
      { href: localizedPath(locale, "/projects"), label: dict.notFound.projects },
      { href: localizedPath(locale, "/blog"), label: dict.notFound.blog },
    ].map((link) => (
      <a
        href={link.href}
        class="inline-flex items-center px-4 py-2 rounded-md text-sm font-medium border transition-colors hover:bg-[var(--color-bg-muted)]"
        style="border-color: var(--color-border); color: var(--color-text);"
      >
        {link.label}
      </a>
    ))}
  </div>
</section>
