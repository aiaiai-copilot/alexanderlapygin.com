---
import { getCollection } from "astro:content";
import { localizedPath, t, type Locale } from "~/i18n";
import { formatDate } from "~/lib/format";
import { readingTimeMinutes } from "~/lib/reading-time";
import { pageSlug } from "~/lib/slug";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

const allPosts = await getCollection("posts", (entry) => {
  return entry.data.lang === locale && !entry.data.draft;
});

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const featured = posts.filter((p) => p.data.featured);
const regular = posts.filter((p) => !p.data.featured);
---

<section class="mx-auto max-w-3xl px-4 md:px-6 pt-16 md:pt-20 pb-8">
  <div class="flex items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <div
        aria-hidden="true"
        class="w-14 h-14 rounded-full flex items-center justify-center text-lg font-semibold"
        style="background-color: var(--color-bg-elev); color: var(--color-text-muted); border: 1px solid var(--color-border);"
      >
        {locale === "ru" ? "АЛ" : "AL"}
      </div>
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight" style="color: var(--color-text);">
        {dict.blog.title}
      </h1>
    </div>
    <a
      href={localizedPath(locale, "/blog/rss.xml")}
      aria-label={dict.blog.rssLabel}
      class="p-2 rounded-md hover:bg-[var(--color-bg-muted)]"
      style="color: var(--color-text-muted);"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 11a9 9 0 0 1 9 9"></path>
        <path d="M4 4a16 16 0 0 1 16 16"></path>
        <circle cx="5" cy="19" r="1"></circle>
      </svg>
    </a>
  </div>
</section>

{posts.length === 0 && (
  <section class="mx-auto max-w-3xl px-4 md:px-6 py-12">
    <p style="color: var(--color-text-muted);">{dict.blog.empty}</p>
  </section>
)}

{featured.length > 0 && (
  <section class="mx-auto max-w-3xl px-4 md:px-6 py-8">
    <h2 class="text-xs uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">
      {dict.blog.featuredHeading}
    </h2>
    <div class="space-y-6">
      {featured.map((post) => (
        <a
          href={localizedPath(locale, `/blog/${pageSlug(post.id)}`)}
          class="block rounded-lg p-6 border hover:bg-[var(--color-bg-muted)] transition-colors"
          style="background-color: var(--color-bg-elev); border-color: var(--color-border);"
        >
          <div class="flex flex-wrap gap-1.5 mb-3">
            {post.data.tags.map((tag) => (
              <span
                class="text-xs px-2 py-0.5 rounded-full"
                style="background-color: var(--color-bg-muted); color: var(--color-text-muted);"
              >
                {tag}
              </span>
            ))}
          </div>
          <h3 class="font-semibold text-xl mb-2" style="color: var(--color-text);">
            {post.data.title}
          </h3>
          <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted);">
            {post.data.description}
          </p>
          <div class="text-xs" style="color: var(--color-text-muted);">
            {formatDate(post.data.pubDate, locale)} · {readingTimeMinutes(post.body ?? "", locale)} {dict.blog.minutesShort}
          </div>
        </a>
      ))}
    </div>
  </section>
)}

{regular.length > 0 && (
  <section class="mx-auto max-w-3xl px-4 md:px-6 py-8 pb-16">
    <h2 class="text-xs uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">
      {dict.blog.allHeading}
    </h2>
    <div class="space-y-2">
      {regular.map((post) => (
        <a
          href={localizedPath(locale, `/blog/${pageSlug(post.id)}`)}
          class="block py-4 px-4 rounded-md border hover:bg-[var(--color-bg-elev)] transition-colors"
          style="border-color: var(--color-border);"
        >
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
            <h3 class="font-medium text-base" style="color: var(--color-text);">
              {post.data.title}
            </h3>
            <span class="text-xs whitespace-nowrap" style="color: var(--color-text-muted);">
              {formatDate(post.data.pubDate, locale)} · {readingTimeMinutes(post.body ?? "", locale)} {dict.blog.minutesShort}
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
