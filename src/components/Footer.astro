---
import { localizedPath, t, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
const year = new Date().getFullYear();

const tgUsername = import.meta.env.PUBLIC_TELEGRAM_USERNAME ?? "";
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? "";
---

<footer
  class="border-t mt-24"
  style="background-color: var(--color-bg-elev); border-color: var(--color-border);"
>
  <div class="mx-auto max-w-6xl px-4 md:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      <div>
        <div class="font-semibold text-base mb-2" style="color: var(--color-text);">
          {dict.meta.siteAuthor}
        </div>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          {dict.footer.tagline}
        </p>
      </div>

      <div>
        <div class="text-xs uppercase tracking-wider mb-3" style="color: var(--color-text-muted);">
          {dict.footer.servicesHeading}
        </div>
        <ul class="space-y-2 text-sm" style="color: var(--color-text);">
          {dict.footer.services.map((s) => <li>{s}</li>)}
        </ul>
      </div>

      <div>
        <div class="text-xs uppercase tracking-wider mb-3" style="color: var(--color-text-muted);">
          {dict.footer.contactsHeading}
        </div>
        <div class="flex items-center gap-3">
          {contactEmail && (
            <a
              href={`mailto:${contactEmail}`}
              data-track="mailto"
              aria-label={dict.footer.emailAriaLabel}
              class="p-2 rounded-md hover:bg-[var(--color-bg-muted)] transition-colors"
              style="color: var(--color-text);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </a>
          )}
          {tgUsername && (
            <a
              href={`https://t.me/${tgUsername}`}
              rel="noopener"
              target="_blank"
              data-track="telegram-direct"
              aria-label={dict.footer.telegramAriaLabel}
              class="p-2 rounded-md hover:bg-[var(--color-bg-muted)] transition-colors"
              style="color: var(--color-text);"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24zm5.55 8.121-1.85 8.726c-.139.616-.504.769-1.022.479l-2.823-2.082-1.362 1.31c-.151.151-.278.278-.568.278l.202-2.872 5.224-4.722c.227-.202-.05-.314-.353-.113L8.484 13.2l-2.78-.871c-.604-.189-.616-.604.126-.894l10.864-4.19c.504-.189.945.114.78.876z"/>
              </svg>
            </a>
          )}
          <a
            href="https://github.com/alexanderlapygin"
            rel="me noopener"
            target="_blank"
            aria-label={dict.footer.githubAriaLabel}
            class="p-2 rounded-md hover:bg-[var(--color-bg-muted)] transition-colors"
            style="color: var(--color-text);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.92.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18.91-.25 1.89-.38 2.86-.39.97.01 1.95.14 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56C20.21 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs" style="border-color: var(--color-border); color: var(--color-text-muted);">
      <span>{dict.footer.copyright(year)}</span>
      <div class="flex flex-wrap items-center gap-4">
        <a href={localizedPath(locale, "/privacy")} class="hover:underline">{dict.footer.privacy}</a>
        <button type="button" data-cookie-settings class="hover:underline" style="color: inherit; background: none; border: 0; padding: 0; cursor: pointer; font: inherit;">
          {dict.footer.cookieSettings}
        </button>
        <a href={localizedPath(locale, "/blog/rss.xml")} class="hover:underline">{dict.footer.rss}</a>
      </div>
    </div>
  </div>
</footer>
