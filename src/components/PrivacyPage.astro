---
import { t, type Locale } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<section class="mx-auto max-w-3xl px-4 md:px-6 pt-16 md:pt-20 pb-16">
  <h1 class="text-3xl md:text-5xl font-semibold tracking-tight mb-8" style="color: var(--color-text);">
    {dict.privacy.title}
  </h1>
  <div
    class="rounded-lg p-6 border"
    style="background-color: var(--color-bg-elev); border-color: var(--color-border); color: var(--color-text);"
  >
    <p class="text-base leading-relaxed">{dict.privacy.body}</p>
  </div>
</section>
