---
import { t, type Locale } from "~/i18n";
import { localizedPath } from "~/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
---

<section class="mx-auto max-w-3xl px-4 md:px-6 pb-16 text-center">
  <a
    href={localizedPath(locale, "/contact")}
    class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg text-base font-semibold hover:opacity-90 transition-opacity"
    style="background-color: var(--color-accent); color: var(--color-accent-text);"
  >
    {dict.cta.contact}
  </a>
</section>
